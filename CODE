# ---------------------------------------------------------------------------
# Price assumptions used for the Denmark-oriented TEA baseline.
# Sources are documented here because these constants materially affect the
# economic results.  Retrieval date for district-heating and FX data: 2026-05-03.
#
# Methanol product price:
#   User/paper price retained by request: EUR 1,800 per metric ton.
#   This is intentionally NOT replaced with the current Methanex posted price.
#
# District-heating product price:
#   Danish Utility Regulator (Forsyningstilsynet), January 2026 district-heating
#   price statistics: weighted average price = DKK 16,953 per year for a
#   130 m² standard house with annual heat consumption of 18.1 MWh.
#   Converted here to DKK/MWh, DKK/GJ, and USD/GJ for hot-water revenue.
#   Source: https://forsyningstilsynet.dk/analyser-og-tal/forbrugerpriser/fjernvarmepriser
#
# Currency conversion:
#   European Central Bank reference rates for 2026-04-30:
#   EUR 1 = USD 1.1702 and EUR 1 = DKK 7.4716.
#   Source: https://www.ecb.europa.eu/stats/policy_and_exchange_rates/euro_reference_exchange_rates/html/index.en.html
#
# Optional gas-price reference, not used by default because the original paper
# used a fixed LNG fuel-cost assumption.  European TTF gas on 2026-05-01 was
# EUR 45.41/MWh, equivalent to about USD 14.76/GJ using the ECB FX rate above.
#   Source: https://tradingeconomics.com/commodity/eu-natural-gas
# ---------------------------------------------------------------------------
EUR_TO_USD: float = 1.1702
DKK_PER_EUR: float = 7.4716
DKK_PER_USD: float = DKK_PER_EUR / EUR_TO_USD
USD_PER_DKK: float = 1.0 / DKK_PER_USD

METHANOL_PRICE_SCENARIO: str = "european_posted_contract_retained_1800_eur_t"
METHANOL_PRICE_PER_TON_EUR: float = 1800.0
METHANOL_PRICE_PER_TON_USD: float = METHANOL_PRICE_PER_TON_EUR * EUR_TO_USD
# Scenario only, not the default: estimated regulatory/shipping value of e-methanol
# from Methanol Institute analysis, average maximum price for 2025-2033.
# Source: https://methanol.org/wp-content/uploads/2024/09/ECONOMIC-VALUE-OF-METHANOL-FOR-SHIPPING-PAPER_final.pdf
E_METHANOL_VALUE_SCENARIO_EUR_PER_TON: float = 2_238.0
E_METHANOL_VALUE_SCENARIO_USD_PER_TON: float = E_METHANOL_VALUE_SCENARIO_EUR_PER_TON * EUR_TO_USD

DENMARK_DH_STANDARD_HOUSE_PRICE_DKK_PER_YEAR_2026: float = 16_953.0
DENMARK_DH_STANDARD_HOUSE_HEAT_MWH_PER_YEAR_2026: float = 18.1
# Updated Denmark district-heating / hot-water price from Forsyningstilsynet
# January 2026 weighted-average price statistics for a 130 m² standard house.
# This replaces the fixed paper/user value of 25.5 USD/GJ.
HOT_WATER_PRICE_PER_MWH_DKK: float = (
    DENMARK_DH_STANDARD_HOUSE_PRICE_DKK_PER_YEAR_2026
    / DENMARK_DH_STANDARD_HOUSE_HEAT_MWH_PER_YEAR_2026
)
HOT_WATER_PRICE_PER_GJ_DKK: float = HOT_WATER_PRICE_PER_MWH_DKK / 3.6
HOT_WATER_PRICE_PER_GJ: float = HOT_WATER_PRICE_PER_GJ_DKK / DKK_PER_USD

# Paper input-cost assumptions retained for base-case compatibility unless the
# user deliberately replaces them.  These are costs, not product prices.
LNG_COST_PER_GJ: float = 7.78
CURRENT_EU_TTF_GAS_COST_USD_PER_GJ: float = 45.41 / 3.6 * EUR_TO_USD
ELECTRICITY_COST_PER_KWH: float = 0.045
O_AND_M_FACTOR: float = 0.06
O_AND_M_BASIS: Literal["FCI", "PEC"] = "PEC"

# Molecular weights used for oxygen/RWGS/methanol stream calculations.
MW_CO2_KG_PER_KMOL: float = 44.0095
MW_H2_KG_PER_KMOL: float = 2.01588
MW_METHANOL_KG_PER_KMOL: float = 32.04186

# Oxygen and LOX accounting.  The stream table gives 2.00 kg/s O2 entering
# the Allam combustor (Stream 2) and 0.44 kg/s O2 produced by the PEM electrolyzer
# (Stream 16).  The corrected purchased-LOX requirement is therefore 1.56 kg/s.
ACC_OXYGEN_TO_COMBUSTOR_KG_S: float = float(STREAMS.loc[2, "m_kg_s"])
PEM_OXYGEN_BYPRODUCT_KG_S: float = float(STREAMS.loc[16, "m_kg_s"])
LOX_MASS_FLOW_KG_S: float = ACC_OXYGEN_TO_COMBUSTOR_KG_S - PEM_OXYGEN_BYPRODUCT_KG_S
if not math.isclose(LOX_MASS_FLOW_KG_S, 1.56, rel_tol=0.0, abs_tol=1e-9):
    raise ValueError(f"Expected corrected purchased LOX = 1.56 kg/s, got {LOX_MASS_FLOW_KG_S}")
LOX_PRICE_PER_TON_EUR: float = 120.0
LOX_PRICE_PER_TON_USD: float = LOX_PRICE_PER_TON_EUR * EUR_TO_USD

# Methanol lower heating value basis and baseline product data.
METHANOL_LHV_KJ_PER_KG: float = 19_900.0
BASELINE_METHANOL_MASS_KG_S: float = float(STREAMS.loc[56, "m_kg_s"])
# The paper's performance table reports 5,328 kW; the LHV-based value from
# 0.27 kg/s and 19.9 MJ/kg is 5,373 kW.  The table value is retained for
# baseline comparability, while the LHV equation is used for non-baseline cases.
BASELINE_METHANOL_ENERGY_KW: float = 5_328.0
# Use the same methanol energy basis for sensitivity cases.  This makes the
# reported baseline mass flow of 0.27 kg/s exactly correspond to the paper's
# reported methanol energy of 5,328 kW.
METHANOL_TABLE_ENERGY_KJ_PER_KG: float = BASELINE_METHANOL_ENERGY_KW / BASELINE_METHANOL_MASS_KG_S


def methanol_product_energy_kw_from_mass(methanol_mass_kg_s: float) -> float:
    """Return methanol product energy on the paper/table basis.

    The original LHV value (19,900 kJ/kg) is kept above as a reference, but the
    TEA denominator and sensitivity results use the paper's own reported energy
    basis: 0.27 kg/s methanol -> 5,328 kW.
    """
    return float(methanol_mass_kg_s) * METHANOL_TABLE_ENERGY_KJ_PER_KG


# Heating power generation in the system used as the marketable hot-water /
# district-heating load for revenue and LCP calculations.
# User-specified correction: 5,387 kW.
BASELINE_HOT_WATER_MASS_KG_S: float = float(STREAMS.loc[18, "m_kg_s"])
STREAMS_18_TO_19_HOT_WATER_LOAD_KW: float = BASELINE_HOT_WATER_MASS_KG_S * (
    float(STREAMS.loc[19, "h_kJ_per_kg"]) - float(STREAMS.loc[18, "h_kJ_per_kg"])
)
BASELINE_HEATING_LOAD_KW: float = 5_387.0
# Corrected product basis used in the sensitivity LCP calculations.  The old
# Aspen hot-water sensitivity values (~18-21 MW) are retained only as diagnostic
# input data; they are no longer used in the LCP denominator.
SENSITIVITY_DISTRICT_HEATING_KW: float = BASELINE_HEATING_LOAD_KW
SENSITIVITY_PRODUCT_BASIS_DESCRIPTION: str = (
    "corrected product basis: district heating = 5,387 kW; "
    "methanol energy uses the paper/table basis from Stream 56, where 0.27 kg/s = 5,328 kW"
)

# Guardrails for the corrected basis requested for this paper revision.
