def run_all_sensitivity_outputs(
    *,
    wind_treatment: WindTreatment = "owned",
    output_dir: str | Path = "results",
    make_plots: bool = True,
    show_plots: bool = False,
) -> tuple[pd.DataFrame, pd.DataFrame, dict[str, Any]]:
    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    baseline = calculate_system_economics(wind_treatment=wind_treatment)
    acc_results = run_acc_lcp_sensitivity(
        wind_treatment=wind_treatment,
        output_dir=output_path,
        save_outputs=True,
        make_plots=make_plots,
        show_plots=show_plots,
    )
    co2_results = run_co2_lcp_sensitivity(
        wind_treatment=wind_treatment,
        output_dir=output_path,
        save_outputs=True,
        make_plots=make_plots,
        show_plots=show_plots,
    )
    write_sensitivity_excel(
        baseline_results=baseline,
        acc_results=acc_results,
        co2_results=co2_results,
        output_file=output_path / "sensitivity_lcp_recalculated.xlsx",
    )
    return acc_results, co2_results, baseline


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Recalculate LCP with corrected district-heating and methanol product-energy values."
    )
    parser.add_argument(
        "--wind-treatment",
        choices=["owned", "purchased", "free"],
        default="owned",
        help="How wind power is treated in the economics. Default: owned.",
    )
    parser.add_argument(
        "--output-dir",
        default="results",
        help="Directory where CSV, Excel, and plot outputs are written.",
    )
    parser.add_argument("--no-plots", action="store_true", help="Do not generate PNG plots.")
    parser.add_argument("--show-plots", action="store_true", help="Show plots interactively after saving.")
    # parse_known_args keeps the script safe in Colab/Jupyter, which injects
    # arguments such as -f kernel.json.
    args, _unknown = parser.parse_known_args()
    return args


def main() -> None:
    args = parse_args()
    output_path = Path(args.output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    baseline = print_economic_analysis(calculate_system_economics(wind_treatment=args.wind_treatment))
    acc_results, co2_results, _ = run_all_sensitivity_outputs(
        wind_treatment=args.wind_treatment,
        output_dir=output_path,
        make_plots=not args.no_plots,
        show_plots=args.show_plots,
    )

    print("\nSensitivity outputs written to:")
    print(f"  {output_path / 'acc_lcp_recalculated.csv'}")
    print(f"  {output_path / 'co2_lcp_recalculated.csv'}")
    print(f"  {output_path / 'sensitivity_lcp_recalculated.xlsx'}")
    if not args.no_plots:
        print(f"  {output_path / 'acc_aspen_input_data.png'}")
        print(f"  {output_path / 'acc_lcp_recalculated.png'}")
        print(f"  {output_path / 'co2_aspen_wind_efficiency_input.png'}")
        print(f"  {output_path / 'co2_lcp_cce_recalculated.png'}")

    print("\nACC LCP range:")
    print(
        f"  {acc_results['LCP_USD_per_kWh'].min():.5f} - "
        f"{acc_results['LCP_USD_per_kWh'].max():.5f} $/kWh"
    )
    print("CO2-to-methanol LCP range:")
    print(
        f"  {co2_results['LCP_USD_per_kWh'].min():.5f} - "
        f"{co2_results['LCP_USD_per_kWh'].max():.5f} $/kWh"
    )


if __name__ == "__main__":
    main()


