def calculate_levelized_cost(
    tac: float,
    energy_product_kw: float,
    hours: int = OPERATING_HOURS_PER_YEAR,
) -> float:
    tac = _require_positive("tac", tac, allow_zero=True)
    energy_product_kw = _require_positive("energy_product_kw", energy_product_kw)
    if hours <= 0:
        raise ValueError("hours must be positive")
    return tac / (energy_product_kw * hours)


def calculate_annual_income_components(
    methanol_mass_kg_s: float,
    hot_water_energy_kw: float,
    hours: int = OPERATING_HOURS_PER_YEAR,
) -> dict[str, float]:
    """Return annual product-revenue components using the current product prices.

    Methanol revenue equation used in the paper:
        R_MeOH = m_dot_MeOH[kg/s] * 3.6[t/h per kg/s] * P_MeOH[$/t] * t_op[h/y]

    District-heating/hot-water revenue equation:
        R_heat = Q_heat[kW] * 0.0036[GJ/h per kW] * P_heat[$/GJ] * t_op[h/y]
    """
    methanol_mass_kg_s = _require_positive("methanol_mass_kg_s", methanol_mass_kg_s, allow_zero=True)
    hot_water_energy_kw = _require_positive("hot_water_energy_kw", hot_water_energy_kw, allow_zero=True)
    if hours < 0:
        raise ValueError("hours cannot be negative")

    methanol_tons_per_hour = methanol_mass_kg_s * 3.6
    methanol_revenue = methanol_tons_per_hour * METHANOL_PRICE_PER_TON_USD * hours

    hot_water_gj_per_hour = hot_water_energy_kw * 0.0036
    hot_water_revenue = hot_water_gj_per_hour * HOT_WATER_PRICE_PER_GJ * hours

    return {
        "Methanol Revenue": methanol_revenue,
        "Hot-Water Revenue": hot_water_revenue,
        "Annual Income": methanol_revenue + hot_water_revenue,
    }


def calculate_annual_income(
    methanol_mass_kg_s: float,
    hot_water_energy_kw: float,
    hours: int = OPERATING_HOURS_PER_YEAR,
) -> float:
    return calculate_annual_income_components(
        methanol_mass_kg_s=methanol_mass_kg_s,
        hot_water_energy_kw=hot_water_energy_kw,
        hours=hours,
    )["Annual Income"]


