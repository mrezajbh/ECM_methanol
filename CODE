###############################################################################
# VALIDATION AND UTILITY FUNCTIONS
###############################################################################

def _require_finite(name: str, value: float) -> float:
    value = float(value)
    if not math.isfinite(value):
        raise ValueError(f"{name} must be finite; got {value!r}")
    return value


def _require_positive(name: str, value: float, *, allow_zero: bool = False) -> float:
    value = _require_finite(name, value)
    if allow_zero:
        if value < 0:
            raise ValueError(f"{name} must be non-negative; got {value}")
    elif value <= 0:
        raise ValueError(f"{name} must be positive; got {value}")
    return value


def format_money(value: float) -> str:
    return "inf" if math.isinf(value) else f"${value:,.0f}"


def format_number(value: float, digits: int = 2) -> str:
    return "inf" if math.isinf(value) else f"{value:,.{digits}f}"


def escalate_cost(cost_ref: float, cepci_current: float, cepci_ref: float) -> float:
    """Escalate a historical equipment cost with CEPCI-style index ratio."""
    cost_ref = _require_positive("cost_ref", cost_ref, allow_zero=True)
    cepci_current = _require_positive("cepci_current", cepci_current)
    cepci_ref = _require_positive("cepci_ref", cepci_ref)
    return cost_ref * cepci_current / cepci_ref

###############################################################################
# COST CORRELATION FUNCTIONS
###############################################################################

def cost_pump(power_kW: float) -> float:
    power_kW = _require_positive("pump power_kW", power_kW)
    return 900.0 * (power_kW / 300.0) ** 0.25


def cost_gas_turbine(power_kW: float) -> float:
    power_kW = _require_positive("gas turbine power_kW", power_kW)
    return 866.64 * power_kW ** 0.82


def cost_turbine(power_kW: float) -> float:
    power_kW = _require_positive("turbine power_kW", power_kW)
    return 6000.0 * power_kW ** 0.7


def cost_exchanger(area_m2: float) -> float:
    area_m2 = _require_positive("heat exchanger area_m2", area_m2)
    return 130.0 * (area_m2 / 0.093) ** 0.78


def cost_wind_turbine(power_MW: float) -> float:
    """Wind turbine purchase cost using Supplementary Part B fit.

    C = 2.12 * P^0.57 million USD, where P is rated power in MW.
    """
    power_MW = _require_positive("wind turbine power_MW", power_MW, allow_zero=True)
    if power_MW == 0:
        return 0.0
    return 2.12 * power_MW ** 0.57 * 1_000_000.0


def cost_compressor(power_kW: float) -> float:
    power_kW = _require_positive("compressor power_kW", power_kW)
    return 9_624.2 * power_kW ** 0.46


def cost_combustion_chamber(
    m_in_kg_s: float,
    p_in_kPa: float,
    p_out_kPa: float,
    T_out_C: float,
) -> float:
    m_in_kg_s = _require_positive("combustion chamber m_in_kg_s", m_in_kg_s)
    p_in_kPa = _require_positive("combustion chamber p_in_kPa", p_in_kPa)
    p_out_kPa = _require_positive("combustion chamber p_out_kPa", p_out_kPa)
    T_out_C = _require_finite("combustion chamber T_out_C", T_out_C)

    pressure_ratio_term = 0.995 - (p_out_kPa / p_in_kPa)
    if pressure_ratio_term <= 0:
        raise ValueError(
            "Combustion-chamber pressure term must be positive: "
            f"0.995 - p_out/p_in = {pressure_ratio_term:.6g}"
        )

    T_out_K = T_out_C + 273.15
    return 46.08 * (m_in_kg_s / pressure_ratio_term) * (
        1.0 + math.exp(0.018 * T_out_K - 26.4)
    )


def cost_methanol_unit(m_gas_in_kg_s: float) -> float:
    m_gas_in_kg_s = _require_positive("methanol unit gas feed m_gas_in_kg_s", m_gas_in_kg_s)
    m_gas_in_kg_h = m_gas_in_kg_s * 3600.0
    return 20_400.0 * m_gas_in_kg_h ** 0.65


def cost_rwgs_plasma_ntp(
    n_tubes: int,
    power_kW: float,
    euro_per_tube: float = 1_000.0,
) -> float:
    """Paper-aligned purchase cost for the RWGS non-thermal plasma reactor.

    This intentionally preserves the Supplementary Part C expression:
    vessel cost = n_tubes * euro_per_tube**0.6 * EUR_TO_USD
    power supply cost = 1500 * power_kW + 900
    """
    if not isinstance(n_tubes, int) or n_tubes <= 0:
        raise ValueError(f"n_tubes must be a positive integer; got {n_tubes!r}")
    power_kW = _require_positive("RWGS plasma power_kW", power_kW)
    euro_per_tube = _require_positive("euro_per_tube", euro_per_tube)

    vessel_cost_usd = n_tubes * (euro_per_tube ** 0.6) * EUR_TO_USD
    power_supply_cost_usd = 1_500.0 * power_kW + 900.0
    return vessel_cost_usd + power_supply_cost_usd


def cost_pem_electrolyzer(power_kW: float) -> float:
    power_kW = _require_positive("PEM electrolyzer power_kW", power_kW)
    return 1_000.0 * power_kW

###############################################################################
# CAPITAL INVESTMENT AND ANNUAL COST FUNCTIONS
###############################################################################

def calculate_direct_costs(purchased_equipment_cost: float) -> float:
    """Direct capital cost from the economic-method table.

    Corrected interpretation of the table rows:
    purchased equipment = 100%; installation = 10%; piping = 70%;
    instrumentation/controls = 40%; electrical = 15%; land = 10%;
    civil/structural/architectural = 90%; service facilities = 100%.

    The old draft omitted land and service facilities and used 35% instead of
    40% for instrumentation.  That old convention can be reproduced only by
    editing these factors intentionally.
    """
    purchased_equipment_cost = _require_positive(
        "purchased_equipment_cost", purchased_equipment_cost, allow_zero=True
    )
    factors = {
        "installation": 0.10,
        "piping": 0.70,
        "instrumentation_and_controls": 0.40,
        "electrical_equipment_and_materials": 0.15,
        "land": 0.10,
        "civil_structural_architectural": 0.90,
        "service_facilities": 1.00,
    }
    return purchased_equipment_cost * (1.0 + sum(factors.values()))


def calculate_indirect_costs(purchased_equipment_cost: float, direct_costs: float) -> float:
    purchased_equipment_cost = _require_positive(
        "purchased_equipment_cost", purchased_equipment_cost, allow_zero=True
    )
    direct_costs = _require_positive("direct_costs", direct_costs, allow_zero=True)
    engineering_supervision = 0.25 * purchased_equipment_cost
    construction_costs = 0.15 * direct_costs
    contingencies = 0.15 * (engineering_supervision + construction_costs)
    return engineering_supervision + construction_costs + contingencies


def calculate_fci(purchased_equipment_cost: float) -> tuple[float, float, float]:
    direct = calculate_direct_costs(purchased_equipment_cost)
    indirect = calculate_indirect_costs(purchased_equipment_cost, direct)
    return direct, indirect, direct + indirect


def capital_recovery_factor(
    discount_rate: float = DISCOUNT_RATE,
    lifetime_years: int = SYSTEM_LIFETIME_YEARS,
) -> float:
    discount_rate = _require_finite("discount_rate", discount_rate)
    if lifetime_years <= 0:
        raise ValueError("lifetime_years must be positive")
    if discount_rate < 0:
        raise ValueError("discount_rate cannot be negative")
    if discount_rate == 0:
        return 1.0 / lifetime_years
    factor = (1.0 + discount_rate) ** lifetime_years
    return discount_rate * factor / (factor - 1.0)


def calculate_o_and_m_cost(cost_basis: float, factor: float = O_AND_M_FACTOR) -> float:
    cost_basis = _require_positive("O&M cost_basis", cost_basis, allow_zero=True)
    factor = _require_positive("O&M factor", factor, allow_zero=True)
    return factor * cost_basis


def calculate_lng_fuel_cost(
    lng_power_kw: float,
    hours: int = OPERATING_HOURS_PER_YEAR,
    lng_cost_per_gj: float = LNG_COST_PER_GJ,
) -> float:
    lng_power_kw = _require_positive("lng_power_kw", lng_power_kw, allow_zero=True)
    if hours < 0:
        raise ValueError("hours cannot be negative")
    lng_cost_per_gj = _require_positive("lng_cost_per_gj", lng_cost_per_gj, allow_zero=True)
    lng_energy_gj = lng_power_kw * hours * 0.0036
    return lng_energy_gj * lng_cost_per_gj


def calculate_purchased_electricity_cost(
    electricity_power_kw: float,
    hours: int = OPERATING_HOURS_PER_YEAR,
    electricity_cost_per_kwh: float = ELECTRICITY_COST_PER_KWH,
) -> float:
    electricity_power_kw = _require_positive("electricity_power_kw", electricity_power_kw, allow_zero=True)
    if hours < 0:
        raise ValueError("hours cannot be negative")
    electricity_cost_per_kwh = _require_positive(
        "electricity_cost_per_kwh", electricity_cost_per_kwh, allow_zero=True
    )
    return electricity_power_kw * hours * electricity_cost_per_kwh


def calculate_energy_operating_cost(
    lng_power_kw: float,
    purchased_electricity_kw: float = 0.0,
    hours: int = OPERATING_HOURS_PER_YEAR,
) -> float:
    return calculate_lng_fuel_cost(lng_power_kw, hours) + calculate_purchased_electricity_cost(
        purchased_electricity_kw, hours
    )


def calculate_lox_cost(hours: int = OPERATING_HOURS_PER_YEAR) -> float:
    if hours < 0:
        raise ValueError("hours cannot be negative")
    tons_per_hour = LOX_MASS_FLOW_KG_S * 3.6
    return tons_per_hour * LOX_PRICE_PER_TON_USD * hours


def calculate_annual_costs(
    fci: float,
    purchased_equipment_cost: float,
    lng_power_kw: float,
    purchased_electricity_kw: float = 0.0,
    hours: int = OPERATING_HOURS_PER_YEAR,
    include_lox: bool = True,
) -> dict[str, float]:
    fci = _require_positive("fci", fci, allow_zero=True)
    purchased_equipment_cost = _require_positive(
        "purchased_equipment_cost", purchased_equipment_cost, allow_zero=True
    )
    om_basis = fci if O_AND_M_BASIS == "FCI" else purchased_equipment_cost
    annual_om = calculate_o_and_m_cost(om_basis)
    annual_energy = calculate_energy_operating_cost(lng_power_kw, purchased_electricity_kw, hours)
    annual_lox = calculate_lox_cost(hours) if include_lox else 0.0
    annualized_capital = capital_recovery_factor() * fci
    tac = annualized_capital + annual_om + annual_energy + annual_lox
    return {
        "Annualized Capital Cost": annualized_capital,
        "Annual O&M Cost": annual_om,
        "Annual LNG Fuel Cost": calculate_lng_fuel_cost(lng_power_kw, hours),
        "Annual Purchased Electricity Cost": calculate_purchased_electricity_cost(
            purchased_electricity_kw, hours
        ),
        "Annual Energy Operating Cost": annual_energy,
        "Annual LOX Cost": annual_lox,
        "Total Annualized Cost (TAC)": tac,
    }

