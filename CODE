def calculate_project_npv(
    fci: float,
    annual_income: float,
    annual_om_cost: float,
    annual_energy_operating_cost: float,
    annual_lox_cost: float,
    discount_rate: float = DISCOUNT_RATE,
    lifetime_years: int = SYSTEM_LIFETIME_YEARS,
    salvage_value: float = 0.0,
) -> float:
    """Discounted cash-flow NPV.

    Year 0: -FCI.
    Years 1..N: annual income minus non-capital operating costs.
    """
    fci = _require_positive("fci", fci, allow_zero=True)
    annual_income = _require_positive("annual_income", annual_income, allow_zero=True)
    annual_om_cost = _require_positive("annual_om_cost", annual_om_cost, allow_zero=True)
    annual_energy_operating_cost = _require_positive(
        "annual_energy_operating_cost", annual_energy_operating_cost, allow_zero=True
    )
    annual_lox_cost = _require_positive("annual_lox_cost", annual_lox_cost, allow_zero=True)
    salvage_value = _require_positive("salvage_value", salvage_value, allow_zero=True)

    annual_net_cash_flow = (
        annual_income - annual_om_cost - annual_energy_operating_cost - annual_lox_cost
    )
    npv = -fci
    for year in range(1, lifetime_years + 1):
        npv += annual_net_cash_flow / ((1.0 + discount_rate) ** year)
    npv += salvage_value / ((1.0 + discount_rate) ** lifetime_years)
    return npv


def calculate_paper_style_npv(tac: float) -> float:
    """Manuscript-style NPV metric: TAC divided by CRF.

    This reproduces the paper/supplementary-code convention. It is a present
    value of the annualized cost stream, not a discounted net cash-flow NPV.
    """
    tac = _require_positive("tac", tac, allow_zero=True)
    return tac / capital_recovery_factor()


def calculate_payback_period_paper_equation(
    total_capital_investment: float,
    annual_income: float,
) -> float:
    """Payback period as written in the paper's economics section.

    Equation:
        PB = TCI / C_inc

    where TCI is total/fixed capital investment and C_inc is gross annual income
    from the process products.  This intentionally follows the paper equation
    and does not subtract annual O&M, LNG, LOX, or electricity costs.
    """
    total_capital_investment = _require_positive(
        "total_capital_investment", total_capital_investment, allow_zero=True
    )
    annual_income = _require_positive("annual_income", annual_income, allow_zero=True)
    return total_capital_investment / annual_income if annual_income > 0 else float("inf")


