def _polyfit_confidence_band(
    x: pd.Series | np.ndarray,
    y: pd.Series | np.ndarray,
    *,
    degree: int = 3,
    n_grid: int = 200,
) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
    """Return x_grid, y_fit, lower_95, upper_95 for a polynomial OLS fit."""
    x_arr = np.asarray(x, dtype=float)
    y_arr = np.asarray(y, dtype=float)
    x_grid = np.linspace(float(np.min(x_arr)), float(np.max(x_arr)), n_grid)

    # Scale x for numerical stability.
    x_mean = float(np.mean(x_arr))
    x_std = float(np.std(x_arr)) or 1.0
    z = (x_arr - x_mean) / x_std
    z_grid = (x_grid - x_mean) / x_std

    X = np.vander(z, N=degree + 1, increasing=True)
    Xg = np.vander(z_grid, N=degree + 1, increasing=True)
    beta, *_ = np.linalg.lstsq(X, y_arr, rcond=None)
    y_fit = Xg @ beta

    residuals = y_arr - X @ beta
    dof = max(len(x_arr) - X.shape[1], 1)
    s2 = float(np.sum(residuals**2) / dof)
    xtx_inv = np.linalg.pinv(X.T @ X)
    pred_var = np.sum((Xg @ xtx_inv) * Xg, axis=1) * s2
    band = 1.96 * np.sqrt(np.maximum(pred_var, 0.0))
    return x_grid, y_fit, y_fit - band, y_fit + band


def plot_acc_input_data(
    input_df: pd.DataFrame,
    output_file: str | Path,
    *,
    show_plot: bool = False,
) -> None:
    fig, ax = plt.subplots(figsize=(10.5, 7.0))
    ax.plot(input_df["ACC_Temp_C"], input_df["E100_Duty_kW"], marker="o", linewidth=2.0, color="#00CC96", label="E-100 Duty")
    ax.plot(input_df["ACC_Temp_C"], input_df["T100_Power_kW"], marker="s", linewidth=2.0, color="#555555", label="T-100 Power")
    ax.plot(input_df["ACC_Temp_C"], input_df["Wind_Energy_Inlet_kW"], marker="^", linewidth=2.0, color="#FF3B30", label="Wind Energy Inlet")
    hot_water_plot_col = (
        "Corrected_Hot_Water_Energy_for_LCP_kW"
        if "Corrected_Hot_Water_Energy_for_LCP_kW" in input_df.columns
        else "Hot_Water_Energy_kW"
    )
    ax.plot(
        input_df["ACC_Temp_C"],
        input_df[hot_water_plot_col],
        marker="x",
        linewidth=2.0,
        color="#1E73FF",
        label="Hot Water Energy Used for LCP",
    )
    ax.set_xlabel("ACC Inlet Temperature (°C)", fontsize=13, fontweight="bold")
    ax.set_ylabel("Duty/Power (kW)", fontsize=13, fontweight="bold")
    ax.grid(True, linestyle=":", alpha=0.45)
    ax.legend(loc="best", fontsize=11)
    fig.tight_layout()
    fig.savefig(output_file, dpi=300, bbox_inches="tight")
    if show_plot:
        plt.show()
    plt.close(fig)


def plot_acc_lcp_results(
