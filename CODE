    "E-104", "E-105",
]


def subsystem_purchase_cost(component_list: list[str], purchase_costs: dict[str, float]) -> float:
    missing = [comp for comp in component_list if comp not in purchase_costs]
    if missing:
        raise KeyError(f"Missing purchase-cost keys: {missing}")
    return sum(purchase_costs[comp] for comp in component_list)


def calculate_subsystem_economics(purchase_costs: dict[str, float]) -> dict[str, dict[str, float]]:
    subsystem_components = {
        "Allam power unit": ALLAM_COMPONENTS,
        "PEM electrolyzer": ELECTROLYZER_COMPONENTS,
        "Methanol plant": METHANOL_COMPONENTS,
    }
    data: dict[str, dict[str, float]] = {}
    for name, components in subsystem_components.items():
        pec = subsystem_purchase_cost(components, purchase_costs)
        direct = calculate_direct_costs(pec)
        indirect = calculate_indirect_costs(pec, direct)
        tci = direct + indirect
        om_basis = tci if O_AND_M_BASIS == "FCI" else pec
        o_and_m = calculate_o_and_m_cost(om_basis)
        tac_without_fuel = capital_recovery_factor() * tci + o_and_m
        data[name] = {
            "PEC": pec,
            "C_DC": direct,
            "C_ID": indirect,
            "C_O&M": o_and_m,
            "TAC_without_fuel_or_LOX": tac_without_fuel,
            "TCI": tci,
        }
    return data


