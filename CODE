def write_sensitivity_excel(
    *,
    baseline_results: dict[str, Any],
    acc_results: pd.DataFrame,
    co2_results: pd.DataFrame,
    output_file: str | Path,
) -> None:
    """Write Aspen inputs and recalculated LCP results to one Excel file."""
    baseline_rows = []
    for key, value in baseline_results.items():
        if isinstance(value, dict):
            continue
        baseline_rows.append({"Metric": key, "Value": value})
    baseline_df = pd.DataFrame(baseline_rows)

    perf_df = pd.DataFrame(
        [{"Metric": k, "Value": v} for k, v in baseline_results["System Performance"].items()]
    )
    refs_df = pd.DataFrame(
        [
            {"Input": name, **details}
            for name, details in PRICE_REFERENCES.items()
        ]
    )

    with pd.ExcelWriter(output_file) as writer:
        baseline_df.to_excel(writer, sheet_name="Baseline_Economics", index=False)
        perf_df.to_excel(writer, sheet_name="Baseline_Performance", index=False)
        get_acc_aspen_input_data().to_excel(writer, sheet_name="ACC_Aspen_Input", index=False)
        acc_results.to_excel(writer, sheet_name="ACC_LCP_Calculated", index=False)
        get_co2_aspen_input_data().to_excel(writer, sheet_name="CO2_Aspen_Input", index=False)
        co2_results.to_excel(writer, sheet_name="CO2_LCP_Calculated", index=False)
        refs_df.to_excel(writer, sheet_name="Price_References", index=False)


