def stoichiometric_methanol_kg_s_from_co2(co2_kmol_h: float) -> float:
    return float(co2_kmol_h) * MW_METHANOL_KG_PER_KMOL / 3600.0


def stoichiometric_gas_feed_kg_s_from_co2(co2_kmol_h: float) -> float:
    # CO2 + 3H2 -> CH3OH + H2O.  This is used only as a scaling basis for the
    # methanol unit purchase-cost correlation when Aspen gas-feed flow is not
    # available at each sensitivity point.
    return float(co2_kmol_h) * (MW_CO2_KG_PER_KMOL + 3.0 * MW_H2_KG_PER_KMOL) / 3600.0


def run_acc_lcp_sensitivity(
    *,
    wind_treatment: WindTreatment = "owned",
    output_dir: str | Path = ".",
    save_outputs: bool = True,
    make_plots: bool = True,
    show_plots: bool = False,
) -> pd.DataFrame:
    """Recalculate LCP for the ACC inlet-temperature Aspen sensitivity."""
    input_df = get_acc_aspen_input_data()
    rows: list[dict[str, float | str]] = []

    for _, r in input_df.iterrows():
        acc_temp = float(r["ACC_Temp_C"])
        e100_duty_kw = float(r["E100_Duty_kW"])
        t100_power_kw = float(r["T100_Power_kW"])
        wind_kw = float(r["Wind_Energy_Inlet_kW"])
        aspen_hot_water_kw = float(r["Hot_Water_Energy_kW"])
        hot_water_kw = SENSITIVITY_DISTRICT_HEATING_KW
        methanol_energy_kw = BASELINE_METHANOL_ENERGY_KW

        economics = calculate_system_economics(
            wind_power_kw=wind_kw,
            wind_treatment=wind_treatment,
            methanol_mass_kg_s=BASELINE_METHANOL_MASS_KG_S,
            methanol_energy_kw=methanol_energy_kw,
            heating_load_kw=hot_water_kw,
            t100_power_kw=t100_power_kw,
            heat_exchanger_q_overrides_kw={"E-100": e100_duty_kw},
        )

        total_energy_product_kw = float(economics["System Performance"]["Total Energy Product (kW)"])
        total_energy_input_kw = BASELINE_LNG_POWER_KW + wind_kw
        calculated_energy_eff_pct = 100.0 * total_energy_product_kw / total_energy_input_kw

        rows.append(
            {
                "ACC_Temp_C": acc_temp,
                "E100_Duty_kW": e100_duty_kw,
                "T100_Power_kW": t100_power_kw,
                "Wind_Energy_Inlet_kW": wind_kw,
                "Hot_Water_Energy_Aspen_kW": aspen_hot_water_kw,
                "Hot_Water_Energy_Used_for_LCP_kW": hot_water_kw,
                "Hot_Water_Energy_kW": hot_water_kw,
                "Methanol_Energy_Used_for_LCP_kW": methanol_energy_kw,
                "Methanol_Energy_kW": methanol_energy_kw,
                "Product_Basis": SENSITIVITY_PRODUCT_BASIS_DESCRIPTION,
                "Total_Energy_Product_kW": total_energy_product_kw,
                "Total_Energy_Input_kW": total_energy_input_kw,
                "Energy_Efficiency_Code_pct": calculated_energy_eff_pct,
                "Energy_Efficiency_Aspen_pct": float(r["Energy_Efficiency_Aspen_pct"]),
                "Exergy_Efficiency_Aspen_pct": float(r["Exergy_Efficiency_Aspen_pct"]),
                "Total_Purchased_Equipment_Cost_USD": float(economics["Total Purchased Equipment Cost"]),
                "FCI_USD": float(economics["Fixed Capital Investment (FCI)"]),
                "Annualized_Capital_Cost_USD": float(economics["Annualized Capital Cost"]),
                "Annual_OM_Cost_USD": float(economics["Annual O&M Cost"]),
                "Annual_LNG_Fuel_Cost_USD": float(economics["Annual LNG Fuel Cost"]),
                "Annual_Purchased_Electricity_Cost_USD": float(economics["Annual Purchased Electricity Cost"]),
                "Annual_LOX_Cost_USD": float(economics["Annual LOX Cost"]),
                "TAC_USD_per_year": float(economics["Total Annualized Cost (TAC)"]),
                "LCP_USD_per_kWh": float(economics["Levelized Cost ($/kWh)"]),
                "Annual_Income_USD": float(economics["Annual Income"]),
                "Payback_Period_years_paper_equation": float(economics["Payback Period (years, paper equation TCI/annual income)"]),
                "Wind_Treatment": wind_treatment,
            }
        )

    results_df = pd.DataFrame(rows)
    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    if save_outputs:
        results_df.to_csv(output_path / "acc_lcp_recalculated.csv", index=False)
    if make_plots:
        plot_acc_input_data(input_df, output_path / "acc_aspen_input_data.png", show_plot=show_plots)
        plot_acc_lcp_results(results_df, output_path / "acc_lcp_recalculated.png", show_plot=show_plots)
    return results_df


