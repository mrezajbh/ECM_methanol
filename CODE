                "Hot_Water_Energy_Inferred_kW": hot_water_kw,
                "Product_Basis": SENSITIVITY_PRODUCT_BASIS_DESCRIPTION,
                "Total_Energy_Product_kW": methanol_energy_kw + hot_water_kw,
                "Energy_Efficiency_Aspen_pct": float(r["Energy_Efficiency_Aspen_pct"]),
                "Energy_Efficiency_Code_pct": 100.0 * (methanol_energy_kw + hot_water_kw) / total_input_kw,
                "Energy_Efficiency_Code_Check_pct": 100.0 * (methanol_energy_kw + hot_water_kw) / total_input_kw,
