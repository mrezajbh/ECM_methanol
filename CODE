def calculate_system_economics(
    *,
    lng_power_kw: float = BASELINE_LNG_POWER_KW,
    wind_power_kw: float = BASELINE_WIND_POWER_KW,
    wind_turbine_rated_power_kw: float | None = None,
    wind_treatment: WindTreatment = "owned",
    methanol_mass_kg_s: float = BASELINE_METHANOL_MASS_KG_S,
    methanol_energy_kw: float | None = None,
    methanol_gas_feed_kg_s: float | None = None,
    heating_load_kw: float = BASELINE_HEATING_LOAD_KW,
    t100_power_kw: float | None = None,
    heat_exchanger_q_overrides_kw: dict[str, float] | None = None,
    heat_exchanger_lmtd_overrides_c: dict[str, float] | None = None,
    heat_exchanger_u_overrides_kw_per_m2K: dict[str, float] | None = None,
    include_lox: bool = True,
    hours: int = OPERATING_HOURS_PER_YEAR,
) -> dict[str, Any]:
    if wind_treatment not in {"owned", "purchased", "free"}:
        raise ValueError("wind_treatment must be 'owned', 'purchased', or 'free'")

    include_wind_turbine = wind_treatment == "owned" and wind_power_kw > 0
    purchased_electricity_kw = wind_power_kw if wind_treatment == "purchased" else 0.0

    purchase_costs = calculate_equipment_purchase_costs(
        wind_power_kw=wind_power_kw,
        wind_turbine_rated_power_kw=wind_turbine_rated_power_kw,
        include_wind_turbine=include_wind_turbine,
        t100_power_kw=t100_power_kw,
        methanol_gas_feed_kg_s=methanol_gas_feed_kg_s,
        heat_exchanger_q_overrides_kw=heat_exchanger_q_overrides_kw,
        heat_exchanger_lmtd_overrides_c=heat_exchanger_lmtd_overrides_c,
        heat_exchanger_u_overrides_kw_per_m2K=heat_exchanger_u_overrides_kw_per_m2K,
    )
    total_purchased_cost = sum(purchase_costs.values())
    direct_costs, indirect_costs, fci = calculate_fci(total_purchased_cost)

    annual_costs = calculate_annual_costs(
        fci=fci,
        purchased_equipment_cost=total_purchased_cost,
        lng_power_kw=lng_power_kw,
        purchased_electricity_kw=purchased_electricity_kw,
        hours=hours,
        include_lox=include_lox,
    )
    tac = annual_costs["Total Annualized Cost (TAC)"]

    if methanol_energy_kw is None:
        if math.isclose(
            methanol_mass_kg_s,
            BASELINE_METHANOL_MASS_KG_S,
            rel_tol=0.0,
            abs_tol=1e-9,
        ):
            methanol_energy_kw = BASELINE_METHANOL_ENERGY_KW
        else:
            methanol_energy_kw = methanol_product_energy_kw_from_mass(methanol_mass_kg_s)
    total_energy_product_kw = methanol_energy_kw + heating_load_kw
    total_energy_input_kw = lng_power_kw + wind_power_kw
    levelized_cost = calculate_levelized_cost(tac, total_energy_product_kw, hours)
    energy_efficiency = total_energy_product_kw / total_energy_input_kw if total_energy_input_kw > 0 else float("nan")

    revenue_components = calculate_annual_income_components(methanol_mass_kg_s, heating_load_kw, hours)
    annual_income = revenue_components["Annual Income"]
    annual_net_operating_cash_flow = (
        annual_income
        - annual_costs["Annual O&M Cost"]
        - annual_costs["Annual Energy Operating Cost"]
        - annual_costs["Annual LOX Cost"]
    )
    annual_equivalent_profit = annual_income - tac
    paper_style_npv = calculate_paper_style_npv(tac)
    payback_period = calculate_payback_period_paper_equation(fci, annual_income)
    npv = calculate_project_npv(
        fci=fci,
        annual_income=annual_income,
        annual_om_cost=annual_costs["Annual O&M Cost"],
        annual_energy_operating_cost=annual_costs["Annual Energy Operating Cost"],
        annual_lox_cost=annual_costs["Annual LOX Cost"],
    )

    return {
        "Equipment Purchase Costs (USD)": purchase_costs,
        "Total Purchased Equipment Cost": total_purchased_cost,
        "Direct Costs": direct_costs,
        "Indirect Costs": indirect_costs,
        "Fixed Capital Investment (FCI)": fci,
        "Capital Recovery Factor": capital_recovery_factor(),
        **annual_costs,
        "Levelized Cost ($/kWh)": levelized_cost,
        "Methanol Revenue": revenue_components["Methanol Revenue"],
        "Hot-Water Revenue": revenue_components["Hot-Water Revenue"],
        "Annual Income": annual_income,
        "Annual Net Operating Cash Flow": annual_net_operating_cash_flow,
        "Annual Equivalent Profit": annual_equivalent_profit,
        "Present Value of TAC (TAC/CRF, old paper metric)": paper_style_npv,
        "Discounted Cash Flow NPV": npv,
        "Net Present Value (NPV)": npv,
        "Payback Period (years, paper equation TCI/annual income)": payback_period,
        "Price Assumptions": get_price_assumptions(),
        "System Performance": {
            "LNG Power (kW)": lng_power_kw,
            "Wind Electric Power to Process (kW)": wind_power_kw,
            "Wind Turbine Rated Power for CAPEX (kW)": (
                wind_turbine_rated_power_kw
                if wind_turbine_rated_power_kw is not None
                else BASELINE_WIND_TURBINE_RATED_POWER_KW
                if math.isclose(wind_power_kw, BASELINE_WIND_POWER_KW, rel_tol=0.0, abs_tol=1e-9)
                else wind_power_kw
            ),
            "Wind Treatment": wind_treatment,
            "Purchased Electricity (kW)": purchased_electricity_kw,
            "O2 to Allam Combustor, Stream 2 (kg/s)": ACC_OXYGEN_TO_COMBUSTOR_KG_S,
            "PEM O2 Byproduct, Stream 16 (kg/s)": PEM_OXYGEN_BYPRODUCT_KG_S,
            "Purchased LOX Flow Rate (kg/s)": LOX_MASS_FLOW_KG_S if include_lox else 0.0,
            "Methanol Production, Stream 56 (kg/s)": methanol_mass_kg_s,
            "Methanol Energy (kW, LHV/table basis)": methanol_energy_kw,
            "Stream-Derived Hot-Water Load, Streams 18->19 (kW)": STREAMS_18_TO_19_HOT_WATER_LOAD_KW,
            "Heating Power Generation Used for Revenue/LCP (kW)": heating_load_kw,
            "Internal E-103 Heat Recovery from Streams 22->23 (kW)": E103_INTERNAL_HEAT_RECOVERY_KW_ABS,
            "Total Energy Product (kW)": total_energy_product_kw,
            "Total Energy Input (kW)": total_energy_input_kw,
            "Energy Efficiency (%)": energy_efficiency * 100.0,
            "Operating Hours/Year": hours,
        },
    }

