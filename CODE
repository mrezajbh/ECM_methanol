# HEAT EXCHANGER SIZING AND PURCHASE COST ASSEMBLY
###############################################################################

def heat_exchanger_area_m2(
    q_kw: float,
    lmtd_c: float,
    u_kw_per_m2K: float,
) -> float:
    q_kw = _require_positive("heat exchanger q_kw", q_kw)
    lmtd_c = _require_positive("heat exchanger lmtd_c", lmtd_c)
    u_kw_per_m2K = _require_positive("heat exchanger u_kw_per_m2K", u_kw_per_m2K)
    return q_kw / (u_kw_per_m2K * lmtd_c)


def get_heat_exchanger_design_values(
    component: str,
    q_overrides_kw: dict[str, float] | None = None,
    lmtd_overrides_c: dict[str, float] | None = None,
    u_overrides_kw_per_m2K: dict[str, float] | None = None,
) -> tuple[float, float, float, float]:
    if component not in HEAT_EXCHANGERS.index:
        raise KeyError(f"Unknown heat exchanger: {component}")

    row = HEAT_EXCHANGERS.loc[component]
    q_kw = row["Q_kW"]
    lmtd_c = row["LMTD_C"]

    if component == "E-103":
        q_kw = E103_INTERNAL_HEAT_RECOVERY_KW_ABS if pd.isna(q_kw) else q_kw
        lmtd_c = E103_ASSUMED_LMTD_C if pd.isna(lmtd_c) else lmtd_c

    if q_overrides_kw and component in q_overrides_kw:
        q_kw = q_overrides_kw[component]
    if lmtd_overrides_c and component in lmtd_overrides_c:
        lmtd_c = lmtd_overrides_c[component]

    if pd.isna(q_kw) or pd.isna(lmtd_c):
        raise ValueError(
            f"Heat exchanger {component} is missing Q or LMTD. "
            "Provide q_overrides_kw/lmtd_overrides_c or explicit assumptions."
        )

    u_kw_per_m2K = HEAT_EXCHANGER_U_KW_PER_M2K.get(
        component, DEFAULT_HEAT_EXCHANGER_U_KW_PER_M2K
    )
    if u_overrides_kw_per_m2K and component in u_overrides_kw_per_m2K:
        u_kw_per_m2K = u_overrides_kw_per_m2K[component]

    area_m2 = heat_exchanger_area_m2(float(q_kw), float(lmtd_c), float(u_kw_per_m2K))
    return float(q_kw), float(lmtd_c), float(u_kw_per_m2K), area_m2


def calculate_equipment_purchase_costs(
    wind_power_kw: float = BASELINE_WIND_POWER_KW,
    wind_turbine_rated_power_kw: float | None = None,
    include_wind_turbine: bool = True,
    t100_power_kw: float | None = None,
    methanol_gas_feed_kg_s: float | None = None,
    rwgs_n_tubes: int = RWGS_BASE_TUBES,
    rwgs_power_kw: float = RWGS_BASE_POWER_KW,
    pem_power_kw: float = PEM_ELECTROLYZER_BASE_POWER_KW,
    heat_exchanger_q_overrides_kw: dict[str, float] | None = None,
    heat_exchanger_lmtd_overrides_c: dict[str, float] | None = None,
    heat_exchanger_u_overrides_kw_per_m2K: dict[str, float] | None = None,
) -> dict[str, float]:
    purchase_costs: dict[str, float] = {}

    if wind_turbine_rated_power_kw is None:
        # For the corrected model, default rated wind capacity equals the
        # reported wind electric power unless the caller supplies a larger
        # installed/rated value.
        wind_turbine_rated_power_kw = (
            BASELINE_WIND_TURBINE_RATED_POWER_KW
            if math.isclose(wind_power_kw, BASELINE_WIND_POWER_KW, rel_tol=0.0, abs_tol=1e-9)
            else wind_power_kw
        )

    for comp, row in PUMPS.iterrows():
        purchase_costs[comp] = cost_pump(float(row["W_kW"]))

    if t100_power_kw is None:
        t100_power_kw = float(TURBINES.loc["T-100", "W_kW"])
    purchase_costs["T-100"] = cost_gas_turbine(t100_power_kw)

    for comp, row in COMPRESSORS.iterrows():
        purchase_costs[comp] = cost_compressor(float(row["W_kW"]))

    use_fixed_baseline_hx_area = (
        USE_PAPER_FIXED_BASELINE_EXCHANGER_AREA
        and heat_exchanger_q_overrides_kw is None
        and heat_exchanger_lmtd_overrides_c is None
        and heat_exchanger_u_overrides_kw_per_m2K is None
    )
    for comp in HEAT_EXCHANGERS.index:
        if use_fixed_baseline_hx_area:
            area_m2 = PAPER_FIXED_HEAT_EXCHANGER_AREA_M2
        else:
            _, _, _, area_m2 = get_heat_exchanger_design_values(
                comp,
                q_overrides_kw=heat_exchanger_q_overrides_kw,
                lmtd_overrides_c=heat_exchanger_lmtd_overrides_c,
                u_overrides_kw_per_m2K=heat_exchanger_u_overrides_kw_per_m2K,
            )
        purchase_costs[comp] = cost_exchanger(area_m2)

    if include_wind_turbine:
        purchase_costs["Wind Turbine"] = cost_wind_turbine(wind_turbine_rated_power_kw / 1_000.0)

    # The combustion-chamber cost correlation requires p_out/p_in < 0.995.
    # The HYSYS model reports no explicit pressure drop, so a 5% pressure-loss
    # design value is used only for the cost correlation.
    purchase_costs["Combustion Chamber"] = cost_combustion_chamber(
        m_in_kg_s=float(STREAMS.loc[6, "m_kg_s"]),
        p_in_kPa=30_000.0,
        p_out_kPa=30_000.0 * 0.95,
        T_out_C=float(STREAMS.loc[8, "T_C"]),
    )

    if methanol_gas_feed_kg_s is None:
        methanol_gas_feed_kg_s = float(STREAMS.loc[49, "m_kg_s"])
    purchase_costs["Methanol Unit"] = cost_methanol_unit(methanol_gas_feed_kg_s)
    purchase_costs["RWGS Plasma NTP"] = cost_rwgs_plasma_ntp(
        n_tubes=rwgs_n_tubes, power_kW=rwgs_power_kw
    )
    purchase_costs["PEM Electrolyzer"] = cost_pem_electrolyzer(pem_power_kw)
    return purchase_costs

